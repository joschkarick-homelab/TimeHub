# TimeHub backup configuration — copy to /etc/timehub/backup.env on the LXC
# host and fill in the values. Read by scripts/backup.sh and scripts/restore.sh.
#
#   install -m 600 scripts/backup.env.example /etc/timehub/backup.env
#
# Keep this file at mode 0600 — it references the S3 credentials.

# --- Deployment layout ------------------------------------------------------
DEPLOY_DIR=/opt/timehub
COMPOSE_FILE=docker-compose.prod.yml
ENV_FILE=stack.env
DB_SERVICE=db
APP_SERVICE=app
PGUSER=timehub
PGDATABASE=timehub

# --- Local HDD (fast-restore tier) -----------------------------------------
BACKUP_ROOT=/mnt/backup-hdd
# Derived from BACKUP_ROOT unless overridden:
# LOCAL_REPO=/mnt/backup-hdd/restic-repo
# STAGING_DIR=/mnt/backup-hdd/staging

# Include stack.env (secrets) in the backup so a restore is self-contained.
# Off by default — the secrets already live in GitHub secrets and are
# re-rendered into stack.env on deploy. Set to true if you want a fully
# self-contained backup (restic encrypts the repo, so it is safe either way).
INCLUDE_ENV_FILE=false

# --- restic auth ------------------------------------------------------------
# Random passphrase, used for BOTH repos. Create with:
#   openssl rand -base64 32 > /etc/timehub/restic-password && chmod 600 /etc/timehub/restic-password
# BACK THIS PASSWORD UP SEPARATELY — without it the off-site backup is unreadable.
RESTIC_PASSWORD_FILE=/etc/timehub/restic-password

# --- Off-site Hetzner S3 (archive tier) ------------------------------------
ENABLE_S3=true
# Hetzner object storage endpoint + bucket. Location prefix is one of
# fsn1 / nbg1 / hel1. Example:
S3_REPO=s3:https://fsn1.your-objectstorage.com/my-bucket/timehub
AWS_ACCESS_KEY_ID=changeme
AWS_SECRET_ACCESS_KEY=changeme

# --- GFS retention: local HDD (shorter) ------------------------------------
KEEP_DAILY=7
KEEP_WEEKLY=4
KEEP_MONTHLY=6
KEEP_YEARLY=0

# --- GFS retention: off-site S3 (longer) -----------------------------------
S3_KEEP_DAILY=14
S3_KEEP_WEEKLY=8
S3_KEEP_MONTHLY=12
S3_KEEP_YEARLY=3
