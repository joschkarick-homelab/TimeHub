# --- App ---
APP_NAME=TimeHub
APP_ENV=production
LOG_LEVEL=info

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-please-use-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# --- Database ---
# Discrete Postgres fields — the app assembles the URL itself with proper
# URL-escaping, so the password may contain any character. Compose files set
# POSTGRES_HOST/PORT/DB/USER for you; only POSTGRES_PASSWORD has to come from
# a secret.
POSTGRES_PASSWORD=changeme-postgres
# POSTGRES_HOST=db
# POSTGRES_PORT=5432
# POSTGRES_DB=timehub
# POSTGRES_USER=timehub

# Optional: set DATABASE_URL to override the assembled URL completely
# (e.g. SQLite for local dev, or an external Postgres host).
# DATABASE_URL=sqlite:///./data/timehub.sqlite

# --- Deployment ---
# Host port the reverse proxy / Proxmox forwards to the app container.
APP_PORT=8000
# Image tag to pull in docker-compose.prod.yml (latest, or a sha-... pin)
TIMEHUB_TAG=latest

# --- Initial admin (created on first start if no users exist) ---
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=changeme
INITIAL_ADMIN_NAME=Admin

# --- CORS (comma-separated origins, or * for all) ---
CORS_ORIGINS=*

# --- AI-assisted CSV mapping (optional) ---
# Leave empty to disable AI suggestions; manual mapping still works.
ANTHROPIC_API_KEY=
AI_MAPPING_MODEL=claude-sonnet-4-6

# --- MCP server (optional) ---
# Mounts a Model Context Protocol server at /mcp so an MCP client (Claude
# Desktop / Claude Code) can read projects and write time entries. Authenticates
# with a TimeHub API key (X-API-Key). Set to false to disable the endpoint.
MCP_ENABLED=true
